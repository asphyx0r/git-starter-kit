# Git configuration template.
# Copy this file to your user Git config, then replace identity placeholders.

[user]
	name = {GIT-USER-NAME}
	email = {GIT-USER-EMAIL}

[core]
	# Default editor for most projects using Visual Studio Code.
	editor = code --wait
	pager = less -FRX
	autocrlf = false
	whitespace = trailing-space,space-before-tab,cr-at-eol

[commit]
	# Enable per repository when .gitmessage exists:
	# template = .gitmessage

[help]
	autocorrect = 0

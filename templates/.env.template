# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
APP_NAME="my-app"
APP_ENV="local"                 # local|dev|staging|prod
APP_DEBUG="false"               # true|false
APP_URL="http://localhost"
APP_HOST="127.0.0.1"             # use 0.0.0.0 only when intentionally exposed
APP_PORT="8080"
APP_TIMEZONE="UTC"
APP_LOCALE="en_US"
APP_VERSION="0.0.0"             # optional, injected by CI

# ------------------------------------------------------------------------------
# Secrets / Crypto (generate these; never commit real values)
# ------------------------------------------------------------------------------
APP_SECRET="__CHANGE_ME__"       # main app secret (sessions/CSRF/etc. depending on stack)
ENCRYPTION_KEY="__CHANGE_ME__"   # application encryption key (if needed)
PASSWORD_PEPPER="__CHANGE_ME__"  # global pepper (in addition to per-user salt)
JWT_SECRET="__CHANGE_ME__"       # if using JWT
JWT_TTL_SECONDS="3600"

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL="info"                 # trace|debug|info|warn|error|fatal
LOG_FORMAT="json"                # json|text
LOG_OUTPUT="stdout"              # stdout|file
LOG_FILE_PATH="./var/app.log"    # if LOG_OUTPUT=file
TRACE_FILE="./trace.$$.log"

# ------------------------------------------------------------------------------
# Network / Reverse proxy / CORS
# ------------------------------------------------------------------------------
TRUST_PROXY="false"              # enable only behind a trusted reverse proxy
TRUSTED_PROXIES=""               # set explicit proxy IPs when TRUST_PROXY=true
CORS_ALLOWED_ORIGINS="http://localhost:3000"
CORS_ALLOWED_METHODS="GET,POST,PUT,PATCH,DELETE,OPTIONS"
CORS_ALLOWED_HEADERS="Authorization,Content-Type"
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_RPS="10"              # requests per second
RATE_LIMIT_BURST="20"

# ------------------------------------------------------------------------------
# Database (generic)
# ------------------------------------------------------------------------------
DB_DRIVER="postgres"             # postgres|mysql|mariadb|mssql|oracle|sqlite
DB_HOST="localhost"
DB_PORT="5432"
DB_NAME="app"
DB_USER="app"
DB_PASSWORD="__CHANGE_ME__"
DB_SSL_MODE="require"            # use disable only for trusted local databases
DB_POOL_MIN="1"
DB_POOL_MAX="10"
DB_CONNECT_TIMEOUT_SECONDS="5"

# ------------------------------------------------------------------------------
# Cache / Redis
# ------------------------------------------------------------------------------
CACHE_DRIVER="redis"             # memory|redis|memcached
CACHE_TTL_SECONDS="300"
REDIS_URL=""                     # e.g., redis://:pass@host:6379/0 (optional)
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""
REDIS_DB="0"

# ------------------------------------------------------------------------------
# Sessions (if applicable)
# ------------------------------------------------------------------------------
SESSION_DRIVER="redis"           # cookie|redis|db
SESSION_SECRET="__CHANGE_ME__"
SESSION_TTL_SECONDS="1209600"    # 14 days

# ------------------------------------------------------------------------------
# Queue / Jobs (pick one backend)
# ------------------------------------------------------------------------------
QUEUE_DRIVER="none"              # none|redis|rabbitmq|kafka|sqs
QUEUE_CONCURRENCY="5"
RABBITMQ_URL=""
KAFKA_BROKERS=""
SQS_REGION=""
SQS_QUEUE_URL=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ------------------------------------------------------------------------------
# Email / SMTP
# ------------------------------------------------------------------------------
MAIL_DRIVER="smtp"               # smtp|ses|mailgun|none
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="no-reply@example.com"
SMTP_FROM_NAME="My App"
SMTP_TLS="false"                 # true|false

# ------------------------------------------------------------------------------
# File storage
# ------------------------------------------------------------------------------
STORAGE_DRIVER="local"           # local|s3
STORAGE_LOCAL_PATH="./var/storage"
S3_ENDPOINT=""                   # optional (MinIO / custom)
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# ------------------------------------------------------------------------------
# Uploads
# ------------------------------------------------------------------------------
UPLOAD_MAX_MB="25"
UPLOAD_ALLOWED_MIME="image/png,image/jpeg,application/pdf"

# ------------------------------------------------------------------------------
# OAuth (enable as needed)
# ------------------------------------------------------------------------------
OAUTH_GOOGLE_CLIENT_ID=""
OAUTH_GOOGLE_CLIENT_SECRET=""
OAUTH_GOOGLE_REDIRECT_URI=""
OAUTH_GITHUB_CLIENT_ID=""
OAUTH_GITHUB_CLIENT_SECRET=""
OAUTH_GITHUB_REDIRECT_URI=""

# ------------------------------------------------------------------------------
# Observability
# ------------------------------------------------------------------------------
SENTRY_DSN=""
OTEL_SERVICE_NAME="my-app"
OTEL_EXPORTER_OTLP_ENDPOINT=""
OTEL_TRACES_SAMPLER="parentbased_traceidratio"
OTEL_TRACES_SAMPLER_ARG="0.1"
METRICS_ENABLED="true"
METRICS_PORT="9090"

# ------------------------------------------------------------------------------
# External integrations (examples)
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
SLACK_WEBHOOK_URL=""

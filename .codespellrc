[codespell]
check-hidden =
check-filenames =
ignore-words-list = ans
skip = ./.git,./dist,./build,./out,./target,./coverage,./htmlcov,./reports,./test-output,./test-results,./node_modules,./vendor,./.venv,./venv,./.tox,./.cache,./.mypy_cache,./.pytest_cache,./.ruff_cache,./.nox,./.pyre,./.hypothesis,./.ipynb_checkpoints,./.idea,./.phpunit.result.cache,./.phpunit.cache,./.php-cs-fixer.cache,*.lock,*.min.js,*.map,*.svg,*.png,*.jpg,*.jpeg,*.gif,*.pdf
